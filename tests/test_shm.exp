#!/usr/bin/env expect

set ::HARNESS [file join [file dirname [info script]] ../build/tests/harness/shm]
source [file join [file dirname [info script]] common/assert.exp]

harness_start
	assert_match "init: first opener is parent" \
		"init testobj1" \
		"OK parent"
	assert_err "unmap before map returns EOORDR" "unmap"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj2"
	assert_ok "map 4096 succeeds" "map 4096"

	harness_push
		assert_match "init: second opener is child" \
			"init testobj2" \
			"OK child"
	harness_pop

	assert_ok "unmap succeeds" "unmap"
harness_stop

harness_start
	assert_err "map before init returns EOORDR" \
		"map 4096"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj3"
	assert_ok "map 4096 succeeds" "map 4096"
	assert_match "state after map shows fd open, base mapped, correct size" \
		"state" \
		"OK fd=* base=1 size=4096"
	assert_ok "unmap succeeds" "unmap"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj4"
	assert_ok "map 4096 succeeds" "map 4096"
	assert_err "second map returns EOORDR" "map 4096"

	assert_ok "unmap succeeds" "unmap"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj5"
	assert_ok "map 4096 succeeds" "map 4096"

	assert_ok   "write byte 0xAB at offset 0"   "write 0 171"
	assert_eq   "read back byte at offset 0"    "read 0" "OK 171"

	assert_ok   "write byte 0x00 at offset 4095" "write 4095 0"
	assert_eq   "read back byte at offset 4095"  "read 4095" "OK 0"

	assert_ok   "write byte 255 at last byte"    "write 4095 255"
	assert_eq   "read back 255"                  "read 4095" "OK 255"

	assert_ok "unmap succeeds" "unmap"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj6"
	assert_ok "map 4096 succeeds" "map 4096"

	assert_err "write beyond mapping is rejected"  "write 4096 1"
	assert_err "read beyond mapping is rejected"   "read 4096"

	assert_ok "unmap succeeds" "unmap"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj7"
	assert_ok "map 4096 succeeds" "map 4096"

	assert_ok "write succeeds" "write 0 42"

	assert_ok "remap to 8192 succeeds" "remap 8192"
	assert_match "state reflects new size" \
		"state" \
		"OK fd=* base=1 size=8192"

	assert_eq "byte at offset 0 preserved after remap" "read 0" "OK 42"

	assert_ok "write into extended region succeeds" "write 8191 99"
	assert_eq "read from extended region"           "read 8191" "OK 99"

	assert_ok "unmap succeeds" "unmap"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj8"
	assert_ok "map 8192 succeeds" "map 8192"
	assert_ok "write succeeds" "write 0 7"

	assert_ok "remap to 4096 (shrink) succeeds" "remap 4096"
	assert_match "state reflects shrunk size" \
		"state" \
		"OK fd=* base=1 size=4096"

	assert_eq  "byte at offset 0 preserved after shrink" "read 0" "OK 7"
	assert_err "former last byte is now out of bounds"   "read 8191"

	assert_ok "unmap succeeds" "unmap"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj9"
	assert_err "remap without prior map returns EOORDR" "remap 8192"
	assert_err "unmap before map returns EOORDR" "unmap"

	assert_ok "init succeeds" "init testobj9b"
	assert_ok "map 4096 succeeds" "map 4096"
	assert_ok "unmap succeeds" "unmap"
	assert_err "remap after unmap returns EOORDR" "remap 8192"
harness_stop

harness_start
	assert_err "unmap before init/map returns EOORDR" "unmap"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj10"
	assert_ok "map 4096 succeeds" "map 4096"
	assert_ok "unmap succeeds" "unmap"

	assert_match "state after unmap shows fd=-1, base=0, size=0" \
		"state" \
		"OK fd=-1 base=0 size=0"
harness_stop

harness_start
	assert_match "init with special chars in name succeeds" \
		"init hello/world!42" \
		"OK parent"

	assert_ok "map 4096 succeeds" "map 4096"
	assert_ok "unmap succeeds" "unmap"
harness_stop

harness_start
	assert_ok "init succeeds" "init testobj11"
	assert_ok "map 4096 succeeds" "map 4096"
	assert_ok "write succeeds" "write 10 123"

	harness_push
		assert_ok "init succeeds" "init testobj11"
		assert_ok "map 4096 succeeds" "map 4096"
		assert_eq "child reads byte written by parent" "read 10" "OK 123"
		assert_ok "unmap succeeds" "unmap"
	harness_pop

	assert_ok "unmap succeeds" "unmap"
harness_stop

harness_start
	assert_err "unknown command returns ERR" "bogus_command"
harness_stop

summarise

